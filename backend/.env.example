# # ============================================================
# # IRCTC Rail Connect - Backend Environment Variables
# # Copy this to .env and fill in your values
# # NEVER commit .env to git!
# # ============================================================

# # Supabase (get from supabase.com > Project Settings > API)
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# # JWT Secret (generate a random string: openssl rand -hex 32)
# JWT_SECRET=your-super-secret-jwt-key-change-this

# # Server
# PORT=5001
# NODE_ENV=production

# # CORS - your Vercel frontend URL
# FRONTEND_URL=https://your-app.vercel.app

# # Email OTP (use Gmail App Password)
# # Go to Google Account > Security > 2FA > App Passwords
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your-gmail-app-password

# # SMS OTP (optional - Twilio free tier)
# # TWILIO_ACCOUNT_SID=your-twilio-sid
# # TWILIO_AUTH_TOKEN=your-twilio-token
# # TWILIO_PHONE=+1234567890

